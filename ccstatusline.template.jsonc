{
  "$schema": "https://json.schemastore.org/ccstatusline.json",

  // ccstatusline 状态栏配置
  // 修改后运行 :ClaudeCodeGenerateConfig 同步到 ~/.config/ccstatusline/settings.json
  //
  // 文档: https://github.com/sirmalloc/ccstatusline

  "version": 3,
  "lines": [
    // Line 1: 模型 + Git + 成本 + 时长
    [
      {
        "id": "1",
        "type": "model",
        "color": "cyan"
      },
      {
        "id": "2",
        "type": "git-branch",
        "color": "blue"
      },
      {
        "id": "3",
        "type": "git-changes",
        "color": "red"
      },
      {
        "id": "4",
        "type": "session-cost",
        "color": "yellow",
        "rawValue": true
      },
      {
        "id": "5",
        "type": "session-clock",
        "color": "green",
        "rawValue": true
      }
    ],
    // Line 2: Token 用量 + 缓存 + 上下文进度条 + 压缩次数
    [
      {
        "id": "6",
        "type": "tokens-input",
        "color": "green"
      },
      {
        "id": "7",
        "type": "tokens-output",
        "color": "magenta"
      },
      {
        "id": "8",
        "type": "tokens-cached",
        "color": "cyan"
      },
      {
        "id": "9",
        "type": "context-bar",
        "color": "cyan"
      },
      {
        "id": "10",
        "type": "compaction-counter",
        "color": "yellow"
      }
    ],
    // Line 3: 速度(30s窗口) + 限额追踪 + Block 计时
    [
      {
        "id": "11",
        "type": "output-speed",
        "color": "magenta",
        "metadata": {
          "window": "30"
        }
      },
      {
        "id": "12",
        "type": "session-usage",
        "color": "green"
      },
      {
        "id": "13",
        "type": "weekly-usage",
        "color": "blue"
      },
      {
        "id": "14",
        "type": "block-timer",
        "color": "yellow"
      },
      {
        "id": "15",
        "type": "block-reset-timer",
        "color": "brightBlack"
      }
    ],
    // Line 4: 超额用量 + 会话 + 项目
    [
      {
        "id": "16",
        "type": "extra-usage-utilization",
        "color": "red"
      },
      {
        "id": "17",
        "type": "extra-usage-remaining",
        "color": "green"
      },
      {
        "id": "18",
        "type": "session-name",
        "color": "cyan"
      },
      {
        "id": "19",
        "type": "git-root-dir",
        "color": "green"
      }
    ]
  ],
  "flexMode": "full",
  "colorLevel": 2,
  "defaultSeparator": " │ ",
  "powerline": {
    "enabled": false
  }
}
