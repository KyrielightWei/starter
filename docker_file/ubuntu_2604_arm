FROM --platform=linux/arm64 ubuntu:26.04

ENV DEBIAN_FRONTEND=noninteractive
ENV LANG=zh_CN.UTF-8
ENV LANGUAGE=zh_CN:zh
ENV LC_ALL=zh_CN.UTF-8
ENV TERM=xterm-256color

RUN apt-get update && apt-get upgrade -y && \
    apt-get install -y \
    build-essential cmake clangd llvm clang libclang-dev \
    wget curl git unzip sudo zsh tmux neovim python3 python3-pip lua5.1 \
    iputils-ping rsync openssl libssl-dev libncurses-dev libreadline-dev \
    libcurl4-openssl-dev libtirpc-dev flex bison pkg-config autoconf automake \
    global nodejs npm proxychains-ng locales fontconfig \
    fonts-noto-cjk fonts-noto-color-emoji libtool libtool-bin \
    libfmt-dev libspdlog-dev nlohmann-json3-dev libgrpc++-dev \
    protobuf-compiler-grpc openssh-server ninja-build gettext && \
    locale-gen zh_CN.UTF-8 && \
    fc-cache -fv

RUN git clone --branch v0.11.6 --depth 1 https://github.com/neovim/neovim.git /tmp/neovim && \
    cd /tmp/neovim && make CMAKE_BUILD_TYPE=Release && make install && \
    cd / && rm -rf /tmp/neovim

RUN git clone https://github.com/universal-ctags/ctags.git /tmp/ctags && \
    cd /tmp/ctags && ./autogen.sh && ./configure && make && make install && \
    cd / && rm -rf /tmp/ctags

RUN curl -L https://github.com/rizsotto/Bear/archive/refs/tags/3.1.6.zip -o /tmp/bear.zip && \
    unzip /tmp/bear.zip -d /tmp && \
    cd /tmp/Bear-3.1.6 && cmake -DENABLE_UNIT_TESTS=OFF -DENABLE_FUNC_TESTS=OFF . && \
    make -j$(nproc) && make install && \
    cd / && rm -rf /tmp/bear.zip /tmp/Bear-3.1.6

RUN git clone --depth=1 --recursive https://github.com/MaskRay/ccls /tmp/ccls && \
    cd /tmp/ccls && cmake -H. -BRelease && cmake --build Release && cmake --install Release && \
    cd / && rm -rf /tmp/ccls

RUN curl -fsSL https://opencode.ai/install | bash

RUN curl https://sh.rustup.rs -sSf | sh -s -- -y
ENV PATH="/root/.cargo/bin:${PATH}"

RUN curl -LO https://go.dev/dl/go1.22.0.linux-arm64.tar.gz && \
    tar -C /usr/local -xzf go1.22.0.linux-arm64.tar.gz && \
    rm go1.22.0.linux-arm64.tar.gz
ENV GOROOT=/usr/local/go
ENV GOPATH=/root/gowork
ENV PATH="${GOROOT}/bin:${GOPATH}/bin:${PATH}"

RUN mkdir -p /root/tool && \
    git clone https://github.com/KyrielightWei/starter.git /root/tool/starter

RUN sed -i "s/#Port 22/Port 22/" /etc/ssh/sshd_config && \
    sed -i "s/#ListenAddress 0.0.0.0/ListenAddress 0.0.0.0/" /etc/ssh/sshd_config && \
    sed -i "s/#ListenAddress ::/ListenAddress ::/" /etc/ssh/sshd_config && \
    sed -i "s/#PermitRootLogin prohibit-password/PermitRootLogin yes/" /etc/ssh/sshd_config && \
    sed -i "s/#PasswordAuthentication yes/PasswordAuthentication yes/" /etc/ssh/sshd_config && \
    sed -i "s/#PermitEmptyPasswords no/PermitEmptyPasswords yes/" /etc/ssh/sshd_config && \
    ssh-keygen -A && \
    mkdir -p /run/sshd

CMD ["/usr/sbin/sshd", "-D"]
