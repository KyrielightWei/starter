{
  "$schema": "https://opencode.ai/config.json",

  // ═══════════════════════════════════════════════════════════
  // OpenCode 配置模板 - 动态 Provider 🎨
  // model 和 small_model 由系统自动从当前选择的 provider/model 生成
  // 修改后运行 :OpenCodeGenerateConfig 生成最终配置
  // ═══════════════════════════════════════════════════════════

  // model 和 small_model 不在此定义，由 config_resolver.get_defaults() 自动注入

  // 自动更新
  "autoupdate": false,

  // 会话共享
  "share": "manual",

  // ═══════════════════════════════════════════════════════════
  // Provider 配置 - 动态注入 🤖
  // ═══════════════════════════════════════════════════════════
  "provider": {
    // 动态 provider 配置由 config_resolver 自动注入
  },

  // ═══════════════════════════════════════════════════════════
  // 权限配置 - 安全优先 🛡️
  // ═══════════════════════════════════════════════════════════
  "permission": {
    // 文件读取：默认允许，但保护敏感文件
    "read": {
      "*": "allow",
      "*.env": "ask",
      "*.env.*": "ask",
      ".env*": "ask",
      "*credentials*": "ask",
      "*secret*": "ask",
      "*password*": "ask",
      "*token*": "ask"
    },

    // 文件编辑：默认询问
    "edit": {
      "*": "ask",
      "*.lock": "ask"
    },

    // Bash 命令：精细控制
    "bash": {
      "*": "ask",

      // 允许：只读操作
      "ls *": "allow",
      "cat *": "allow",
      "head *": "allow",
      "tail *": "allow",
      "find *": "allow",
      "grep *": "allow",
      "rg *": "allow",
      "git status*": "allow",
      "git log*": "allow",
      "git diff*": "allow",
      "git show*": "allow",
      "git branch*": "allow",

      // 允许：构建和测试
      "npm run build*": "allow",
      "npm run test*": "allow",
      "make*": "allow",
      "cargo build*": "allow",
      "cargo test*": "allow",
      "go build*": "allow",
      "go test*": "allow",

      // 允许：安装依赖
      "npm install*": "allow",
      "pip install*": "allow",

      // 允许：格式化
      "stylua*": "allow",
      "prettier*": "allow",

      // 需要确认：危险操作
      "rm *": "ask",
      "rm -rf *": "ask",
      "git push*": "ask",
      "git reset --hard*": "ask",
      "sudo *": "ask"
    },

    // 外部目录：默认询问
    "external_directory": "ask",

    // 子代理权限
    "task": "ask",
    "skill": "allow"
  },

  // 文件监视器配置
  "watcher": {
    "ignore": [
      "node_modules/**",
      "dist/**",
      ".git/**",
      "*.log",
      ".DS_Store"
    ]
  },

  // 上下文压缩配置
  "compaction": {
    "auto": true,
    "prune": true,
    "reserved": 10000
  }
}
