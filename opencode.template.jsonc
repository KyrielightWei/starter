{
  "$schema": "https://opencode.ai/config.json",

  // OpenCode 配置模板
  // 修改后运行 :OpenCodeGenerateConfig 生成最终配置

  // 默认模型
  "model": "glm-5",

  // 自动更新
  "autoupdate": true,

  // 会话共享
  "share": "manual",

  // 权限配置
  "permission": {},

  // 文件监视器配置
  "watcher": {
    "ignore": [
      "node_modules/**",
      "dist/**",
      ".git/**",
      "*.log"
    ]
  },

  // 上下文压缩配置
  "compaction": {
    "auto": true,
    "prune": true,
    "reserved": 10000
  }
}
