{
  "$schema": "https://pi.dev/settings.json",

  // ═════════════════════════════════════════════════════════════════════════
  // Pi Settings 模板 - Bailian Coding Provider 🎨
  // 当前配置复制到 ~/.pi/agent/settings.json
  // 或在 pi 中运行 /settings 调整常用选项
  // ═════════════════════════════════════════════════════════════════════════

  // ───────────────────────────────────────────────────────────────────────
  // Model & Thinking 🤖
  // ───────────────────────────────────────────────────────────────────────

  // 默认 Provider (bailian 在 models.json 中定义)
  "defaultProvider": "bailian",

  // 默认 Model
  // 推荐: glm-5 (复杂推理), qwen3.6-plus (效果均衡), qwen3.5-plus (快速响应)
  "defaultModel": "glm-5",

  // 默认思考级别
  // off, minimal, low, medium, high, xhigh
  "defaultThinkingLevel": "medium",

  // 隐藏思考块
  "hideThinkingBlock": false,

  // ───────────────────────────────────────────────────────────────────────
  // UI & Display 🎨
  // ───────────────────────────────────────────────────────────────────────

  // 主题名称 (自定义主题在 ~/.pi/agent/themes/ 目录)
  "theme": "flexoki-dark",

  // ───────────────────────────────────────────────────────────────────────
  // Compaction (上下文压缩) 📦
  // ───────────────────────────────────────────────────────────────────────

  "compaction": {
    "enabled": true,
    "reserveTokens": 16384,
    "keepRecentTokens": 20000
  },

  // ───────────────────────────────────────────────────────────────────────
  // Retry (重试策略) 🔄
  // ───────────────────────────────────────────────────────────────────────

  "retry": {
    "enabled": true,
    "maxRetries": 3,
    "baseDelayMs": 2000,
    "provider": {
      "timeoutMs": 3600000,  // 1小时超时 (当前配置)
      "maxRetryDelayMs": 60000
    }
  },

  // ───────────────────────────────────────────────────────────────────────
  // Terminal 🖥️
  // ───────────────────────────────────────────────────────────────────────

  "terminal": {
    "showTerminalProgress": true
  },

  // ───────────────────────────────────────────────────────────────────────
  // Transport 🚚
  // ───────────────────────────────────────────────────────────────────────

  "transport": "sse",

  // ───────────────────────────────────────────────────────────────────────
  // Branch / Tree (会话分支)
  // ───────────────────────────────────────────────────────────────────────

  "branchSummary": {
    "reserveTokens": 16384,
    "skipPrompt": false
  },

  // ───────────────────────────────────────────────────────────────────────
  // Message Delivery
  // ───────────────────────────────────────────────────────────────────────

  "steeringMode": "one-at-a-time",
  "followUpMode": "one-at-a-time",

  // ───────────────────────────────────────────────────────────────────────
  // Packages (已安装) 📦
  // ───────────────────────────────────────────────────────────────────────

  "packages": [
    // Superpowers - 跨工具通用工程方法论 (brainstorming/TDD/debugging/...)
    "git:github.com/obra/superpowers",

    // Flexoki 专注阅读/代码主题
    "npm:flexoki-pi-theme"
  ],

  // ═════════════════════════════════════════════════════════════════════════
  // 可选配置 (未启用，仅供参考)
  // ═════════════════════════════════════════════════════════════════════════

  // 自定义思考预算 (token)
  // "thinkingBudgets": {
  //   "minimal": 1024,
  //   "low": 4096,
  //   "medium": 10240,
  //   "high": 32768,
  //   "xhigh": 65536
  // },

  // 隐藏启动头部
  // "quietStartup": false,

  // 双击 Escape 动作: tree, fork, none
  // "doubleEscapeAction": "tree",

  // 编辑器水平填充 (0-3)
  // "editorPaddingX": 0,

  // 自动完成最大显示项 (3-20)
  // "autocompleteMaxVisible": 5,

  // 图片显示
  // "terminal": {
  //   "showImages": true,
  //   "imageWidthCells": 60
  // },
  // "images": {
  //   "autoResize": true,
  //   "blockImages": false
  // },

  // 可循环的模型 (支持 glob)
  // "enabledModels": ["glm-5", "qwen3.*", "kimi-k2*"],

  // /tree 默认过滤模式
  // "treeFilterMode": "default",

  // 跨工具复用 skill (Claude Code / Codex 的 skill 目录)
  // "skills": [
  //   "~/.claude/skills",
  //   "~/.codex/skills"
  // ],

  // 启用技能命令 (/skill:name)
  // "enableSkillCommands": true,

  // 可选 Packages (未安装)
  // "npm:pi-mcp-adapter",           // MCP 支持
  // "git:github.com/anthropics/skills", // Anthropic 官方 skill
  // "git:github.com/badlogic/pi-skills", // Pi 维护者 skill

  // 遥测和警告
  // "enableInstallTelemetry": true,
  // "warnings": {
  //   "anthropicExtraUsage": true
  // }
}
