{
  "$schema": "https://pi.dev/settings.json",

  // ═════════════════════════════════════════════════════════════════════════
  // Pi Settings 模板 - Bailian Coding Provider 🎨
  // 修改后复制到 ~/.pi/agent/settings.json
  // 或在 pi 中运行 /settings 调整常用选项
  // ═════════════════════════════════════════════════════════════════════════

  // ───────────────────────────────────────────────────────────────────────
  // Model & Thinking 🤖
  // ───────────────────────────────────────────────────────────────────────

  // 默认 Provider (bailian 在 models.json 中定义)
  "defaultProvider": "bailian",

  // 默认 Model
  // 推荐: glm-5 (复杂推理), qwen3.6-plus (效果均衡), qwen3.5-plus (快速响应)
  "defaultModel": "glm-5",

  // 默认思考级别
  // off, minimal, low, medium, high, xhigh
  "defaultThinkingLevel": "medium",

  // 自定义思考预算 (token)
  "thinkingBudgets": {
    "minimal": 1024,
    "low": 4096,
    "medium": 10240,
    "high": 32768,
    "xhigh": 65536
  },

  // 隐藏思考块
  "hideThinkingBlock": false,

  // ───────────────────────────────────────────────────────────────────────
  // UI & Display 🎨
  // ───────────────────────────────────────────────────────────────────────

  // 主题名称 (自定义主题在 ~/.pi/agent/themes/ 目录)
  "theme": "kanagawa",

  // 隐藏启动头部
  "quietStartup": false,

  // 双击 Escape 动作: tree, fork, none
  "doubleEscapeAction": "tree",

  // 编辑器水平填充 (0-3)
  "editorPaddingX": 0,

  // 自动完成最大显示项 (3-20)
  "autocompleteMaxVisible": 5,

  // ───────────────────────────────────────────────────────────────────────
  // Compaction (上下文压缩) 📦
  // ───────────────────────────────────────────────────────────────────────

  "compaction": {
    "enabled": true,
    "reserveTokens": 16384,
    "keepRecentTokens": 20000
  },

  // ───────────────────────────────────────────────────────────────────────
  // Retry (重试策略) 🔄
  // ───────────────────────────────────────────────────────────────────────

  "retry": {
    "enabled": true,
    "maxRetries": 3,
    "baseDelayMs": 2000,
    "provider": {
      "maxRetryDelayMs": 60000
    }
  },

  // ───────────────────────────────────────────────────────────────────────
  // Terminal & Images 🖼️
  // ───────────────────────────────────────────────────────────────────────

  "terminal": {
    "showImages": true,
    "imageWidthCells": 60,
    "showTerminalProgress": true
  },

  "images": {
    "autoResize": true,
    "blockImages": false
  },

  // ───────────────────────────────────────────────────────────────────────
  // Model Cycling (Ctrl+P) 🔃
  // ───────────────────────────────────────────────────────────────────────

  // 可循环的模型 (支持 glob)
  "enabledModels": ["glm-5", "qwen3.*", "kimi-k2*"],

  // ───────────────────────────────────────────────────────────────────────
  // Branch / Tree (会话分支)
  // ───────────────────────────────────────────────────────────────────────

  "branchSummary": {
    "reserveTokens": 16384,
    "skipPrompt": false
  },

  // /tree 默认过滤模式: default | no-tools | user-only | labeled-only | all
  "treeFilterMode": "default",

  // ───────────────────────────────────────────────────────────────────────
  // Message Delivery
  // ───────────────────────────────────────────────────────────────────────

  // steeringMode / followUpMode: "all" 或 "one-at-a-time"
  "steeringMode": "one-at-a-time",
  "followUpMode": "one-at-a-time",

  // ───────────────────────────────────────────────────────────────────────
  // Resources (扩展、技能、Prompt) 📚
  // ───────────────────────────────────────────────────────────────────────

  // 跨工具复用 skill (Claude Code / Codex 的 skill 目录)
  // 路径在 ~/.pi/agent/settings.json 中相对 ~/.pi/agent 解析；~ 和绝对路径都支持
  "skills": [
    "~/.claude/skills",
    "~/.codex/skills"
  ],

  // Pi 包 (npm 或 git)
  "packages": [
    // Superpowers - 跨工具通用工程方法论 (brainstorming/TDD/debugging/...)
    "git:github.com/obra/superpowers",

    // pi-mcp-adapter - MCP 支持（社区方案，单 proxy tool 避免 context bloat）
    // 安装后可用 /mcp 命令；配置文件 ~/.config/mcp/mcp.json 或 .mcp.json
    "npm:pi-mcp-adapter",

    // Anthropic 官方 skill 包 - 文档处理 (docx/pdf/pptx/xlsx)、web 开发
    "git:github.com/anthropics/skills",

    // Pi 维护者的 skill 包 - web search / 浏览器 / Google APIs / transcription
    "git:github.com/badlogic/pi-skills"
  ],

  // 启用技能命令 (/skill:name)
  "enableSkillCommands": true,

  // ───────────────────────────────────────────────────────────────────────
  // Telemetry 📊
  // ───────────────────────────────────────────────────────────────────────

  // 安装/更新遥测 (仅版本 ping)
  // 禁用版本检查: PI_SKIP_VERSION_CHECK=1
  // 禁用所有网络: PI_OFFLINE=1 或 --offline
  "enableInstallTelemetry": true,

  // ───────────────────────────────────────────────────────────────────────
  // Warnings ⚠️
  // ───────────────────────────────────────────────────────────────────────

  "warnings": {
    "anthropicExtraUsage": true
  }
}