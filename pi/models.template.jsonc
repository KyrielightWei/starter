{
  "$schema": "https://pi.dev/models.json",

  // ═════════════════════════════════════════════════════════════════════════
  // Pi Custom Models 模板 - Bailian Coding Provider 🎨
  // 修改后复制到 ~/.pi/agent/models.json
  // 重载: 打开 /model 时自动重载
  // ═════════════════════════════════════════════════════════════════════════

  "providers": {

    // ───────────────────────────────────────────────────────────────────────
    // Bailian Coding (阿里百炼编码版) 🤖
    // 主 Provider，支持多种国产大模型
    // ───────────────────────────────────────────────────────────────────────

    "bailian": {
      "name": "百炼编码",
      "baseUrl": "https://coding.dashscope.aliyuncs.com/v1",
      "api": "openai-completions",
      "apiKey": "OPENAI_API_KEY",

      // 兼容性设置 (部分服务器不支持 developer role)
      "compat": {
        "supportsDeveloperRole": false,
        "supportsReasoningEffort": false
      },

      "models": [
        {
          "id": "glm-5",
          "name": "GLM-5",
          "description": "智谱GLM-5，复杂推理和代码审查",
          "contextWindow": 200000,
          "maxTokens": 8192,
          "cost": { "input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0 }
        },
        {
          "id": "qwen3.5-plus",
          "name": "Qwen 3.5 Plus",
          "description": "阿里Qwen3.5-Plus，适合简单任务和文档生成",
          "contextWindow": 1048576,
          "maxTokens": 65536,
          "cost": { "input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0 }
        },
        {
          "id": "qwen3.6-plus",
          "name": "Qwen 3.6 Plus",
          "description": "阿里Qwen3.6-Plus，效果均衡",
          "contextWindow": 1048576,
          "maxTokens": 65536,
          "cost": { "input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0 }
        },
        {
          "id": "kimi-k2.5",
          "name": "Kimi K2.5",
          "description": "Moonshot Kimi，超长上下文处理",
          "contextWindow": 262144,
          "maxTokens": 98304,
          "cost": { "input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0 }
        },
        {
          "id": "MiniMax-M2.5",
          "name": "MiniMax M2.5",
          "description": "MiniMax模型，多场景支持",
          "contextWindow": 196608,
          "maxTokens": 32768,
          "cost": { "input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0 }
        }
      ]
    },

    // ───────────────────────────────────────────────────────────────────────
    // Ollama (本地 LLM) 🏠
    // 用于离线开发或测试
    // ───────────────────────────────────────────────────────────────────────

    "ollama": {
      "baseUrl": "http://localhost:11434/v1",
      "api": "openai-completions",
      "apiKey": "ollama",
      "compat": {
        "supportsDeveloperRole": false,
        "supportsReasoningEffort": false
      },
      "models": [
        { "id": "qwen2.5-coder:7b", "name": "Qwen 2.5 Coder 7B (Local)" },
        { "id": "deepseek-r1:8b", "name": "DeepSeek R1 8B (Local)" },
        { "id": "llama3.1:8b", "name": "Llama 3.1 8B (Local)" }
      ]
    },

    // ───────────────────────────────────────────────────────────────────────
    // Anthropic (官方 API) 🌐
    // 需要配置 ANTHROPIC_API_KEY 环境变量
    // ───────────────────────────────────────────────────────────────────────

    // "anthropic": {
    //   "apiKey": "ANTHROPIC_API_KEY",
    //   "models": [
    //     { "id": "claude-sonnet-4-20250514", "name": "Claude Sonnet 4", "reasoning": true },
    //     { "id": "claude-opus-4-20250514", "name": "Claude Opus 4", "reasoning": true }
    //   ]
    // },

    // ───────────────────────────────────────────────────────────────────────
    // OpenAI (官方 API) 🌐
    // 需要配置 OPENAI_API_KEY 环境变量
    // ───────────────────────────────────────────────────────────────────────

    // "openai": {
    //   "apiKey": "OPENAI_API_KEY",
    //   "models": [
    //     { "id": "gpt-4o", "name": "GPT-4o" },
    //     { "id": "gpt-4o-mini", "name": "GPT-4o Mini" }
    //   ]
    // }

  }

  // ═════════════════════════════════════════════════════════════════════════
  // API Key 解析规则
  // ═════════════════════════════════════════════════════════════════════════
  //
  // Shell 命令: "!command" - 执行并取 stdout
  //   示例: "!op read 'op://vault/item/credential'"
  //   示例: "!security find-generic-password -ws 'anthropic'"
  //
  // 环境变量: "VAR_NAME" - 使用环境变量值
  //   示例: "ANTHROPIC_API_KEY", "OPENAI_API_KEY"
  //
  // 直接值: "sk-..." - 直接使用
  //   注意: 不要提交到版本控制
  //
  // ═════════════════════════════════════════════════════════════════════════
}