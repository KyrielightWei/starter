{
  "$schema": "https://pi.dev/settings.json",

  // ═════════════════════════════════════════════════════════════════════════
  // Pi Settings 完整模板 ⚙️
  // 修改后复制到 ~/.pi/agent/settings.json
  // 重载: /settings 命令或重启
  // ═════════════════════════════════════════════════════════════════════════

  // ───────────────────────────────────────────────────────────────────────
  // Model & Thinking 🧠
  // ───────────────────────────────────────────────────────────────────────

  "defaultProvider": "bailian",
  "defaultModel": "glm-5",
  "defaultThinkingLevel": "medium",  // off | minimal | low | medium | high | xhigh
  "hideThinkingBlock": false,

  // 自定义思考预算 (token)
  // "thinkingBudgets": {
  //   "minimal": 1024,
  //   "low": 4096,
  //   "medium": 10240,
  //   "high": 32768,
  //   "xhigh": 65536
  // },

  // ───────────────────────────────────────────────────────────────────────
  // UI & Display 🎨
  // ───────────────────────────────────────────────────────────────────────

  "theme": "kanagawa",               // dark | light | custom theme name
  "quietStartup": false,             // 隐藏启动 header
  "collapseChangelog": false,        // 紧凑 changelog
  "doubleEscapeAction": "tree",      // tree | fork | none
  "treeFilterMode": "default",       // default | no-tools | user-only | labeled-only | all
  "editorPaddingX": 0,               // 编辑器水平 padding (0-3)
  "autocompleteMaxVisible": 5,       // 自动补全最大显示数 (3-20)
  "showHardwareCursor": false,       // 显示终端光标

  // ───────────────────────────────────────────────────────────────────────
  // Compaction 📦 (上下文压缩)
  // ───────────────────────────────────────────────────────────────────────

  "compaction": {
    "enabled": true,
    "reserveTokens": 16384,          // LLM 响应预留 token
    "keepRecentTokens": 20000        // 保留最近 token (不被总结)
  },

  // ───────────────────────────────────────────────────────────────────────
  // Branch Summary 🌿
  // ───────────────────────────────────────────────────────────────────────

  "branchSummary": {
    "reserveTokens": 16384,
    "skipPrompt": false              // 跳过 "Summarize branch?" 提示
  },

  // ───────────────────────────────────────────────────────────────────────
  // Retry 🔄 (重试策略)
  // ───────────────────────────────────────────────────────────────────────

  "retry": {
    "enabled": true,
    "maxRetries": 3,                 // 最大 agent 级重试次数
    "baseDelayMs": 2000,             // 指数退避基础延迟 (2s, 4s, 8s)
    "provider": {
      "timeoutMs": 3600000,          // Provider 超时 (ms)
      "maxRetries": 0,               // Provider 重试次数
      "maxRetryDelayMs": 60000       // 最大服务器请求延迟 (60s)
    }
  },

  // ───────────────────────────────────────────────────────────────────────
  // Message Delivery 📨
  // ───────────────────────────────────────────────────────────────────────

  "steeringMode": "one-at-a-time",  // one-at-a-time | all
  "followUpMode": "one-at-a-time",  // one-at-a-time | all
  "transport": "sse",               // sse | websocket | auto

  // ───────────────────────────────────────────────────────────────────────
  // Terminal & Images 🖼️
  // ───────────────────────────────────────────────────────────────────────

  "terminal": {
    "showImages": true,
    "imageWidthCells": 60,           // 图片宽度 (终端单元格)
    "clearOnShrink": false,          // 内容收缩时清空 (可能闪烁)
    "showTerminalProgress": true     // 显示终端进度
  },

  "images": {
    "autoResize": true,              // 自动调整大小 (最大 2000x2000)
    "blockImages": false             // 阻止发送图片到 LLM
  },

  // ───────────────────────────────────────────────────────────────────────
  // Shell 🐚
  // ───────────────────────────────────────────────────────────────────────

  // "shellPath": "/bin/bash",        // 自定义 shell 路径
  // "shellCommandPrefix": "shopt -s expand_aliases",  // 每条命令前缀
  // "npmCommand": ["mise", "exec", "node@20", "--", "npm"],  // npm 包装器

  // ───────────────────────────────────────────────────────────────────────
  // Warnings ⚠️
  // ───────────────────────────────────────────────────────────────────────

  "warnings": {
    "anthropicExtraUsage": true      // Anthropic 订阅额外用量警告
  },

  // ───────────────────────────────────────────────────────────────────────
  // Telemetry 📊
  // ───────────────────────────────────────────────────────────────────────

  "enableInstallTelemetry": true,   // 发送匿名安装/更新 ping

  // ───────────────────────────────────────────────────────────────────────
  // Packages 📦 (Pi 包)
  // ───────────────────────────────────────────────────────────────────────

  "packages": [
    // npm 包
    // "npm:@scope/pi-tools@1.0.0",

    // git 包 (支持 @ref 锁定)
    "git:github.com/obra/superpowers"

    // 本地路径
    // "/path/to/local/package"
  ],

  // ───────────────────────────────────────────────────────────────────────
  // Extensions 🔌 (额外扩展路径)
  // ───────────────────────────────────────────────────────────────────────

  // "extensions": [
  //   "/path/to/extension.ts",
  //   "/path/to/extension/dir"
  // ],

  // ───────────────────────────────────────────────────────────────────────
  // Tools 🛠️ (工具配置)
  // ───────────────────────────────────────────────────────────────────────

  // "tools": {
  //   "builtin": ["read", "bash", "edit", "write"],  // 启用的内置工具
  //   "bashTimeout": 120000  // bash 命令超时 (ms)
  // },

  // ───────────────────────────────────────────────────────────────────────
  // Custom Scopes (模型分组)
  // ───────────────────────────────────────────────────────────────────────

  // "scopedModels": {
  //   "fast": ["qwen3.5-plus"],
  //   "smart": ["glm-5", "qwen3.6-plus"],
  //   "coding": ["qwen3.6-plus"]
  // },

  // ═════════════════════════════════════════════════════════════════════════
  // 环境变量 (替代配置)
  // ═════════════════════════════════════════════════════════════════════════
  //
  // PI_CODING_AGENT_DIR      - 覆盖配置目录 (默认 ~/.pi/agent)
  // PI_CODING_AGENT_SESSION_DIR - 覆盖会话存储目录
  // PI_PACKAGE_DIR           - 覆盖包目录
  // PI_OFFLINE               - 禁用启动网络操作 (包括更新检查)
  // PI_SKIP_VERSION_CHECK    - 跳过 Pi 版本更新检查
  // PI_TELEMETRY             - 覆盖遥测设置 (1/true/yes 或 0/false/no)
  // PI_CACHE_RETENTION       - 设置为 "long" 扩展缓存保留
  // VISUAL / EDITOR          - Ctrl+G 外部编辑器
  //
  // ═════════════════════════════════════════════════════════════════════════
}