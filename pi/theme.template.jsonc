{
  "$schema": "https://raw.githubusercontent.com/earendil-works/pi/main/packages/coding-agent/src/modes/interactive/theme/theme-schema.json",

  // ═════════════════════════════════════════════════════════════════════════
  // Pi Theme 模板 - Kanagawa Wave 风格 🎨
  // 修改后复制到 ~/.pi/agent/themes/kanagawa.json
  // 热重载: 修改当前主题文件立即生效
  // ═════════════════════════════════════════════════════════════════════════

  "name": "Kanagawa Wave",

  // 可复用颜色变量 (Kanagawa 风格)
  "vars": {
    "sumiInk0": "#16161d",
    "sumiInk1": "#1e1f28",
    "sumiInk3": "#363646",
    "sumiInk4": "#2a2a37",
    "fujiWhite": "#dcd7ba",
    "oldWhite": "#c8c093",
    "fujiGray": "#727169",
    "katanaGray": "#717c7c",
    "springGreen": "#98bb6c",
    "springBlue": "#7fb4ca",
    "oniViolet": "#957fb8",
    "crystalBlue": "#7e9cd8",
    "peachRed": "#ff5d62",
    "surimiOrange": "#ffa066",
    "carpYellow": "#e6c384",
    "sakuraPink": "#d27e99",
    "waveAqua": "#6a9589",
    "dragonBlue": "#658594",
    "winterBlue": "#252535",
    "winterGreen": "#2b3328",
    "springViolet1": "#938aa9"
  },

  // ═════════════════════════════════════════════════════════════════════════
  // Core UI (11 colors)
  // ═════════════════════════════════════════════════════════════════════════

  "colors": {
    "accent": "springBlue",
    "border": "sumiInk3",
    "borderAccent": "crystalBlue",
    "borderMuted": "sumiInk4",
    "success": "springGreen",
    "error": "peachRed",
    "warning": "surimiOrange",
    "muted": "fujiGray",
    "dim": "katanaGray",
    "text": "",
    "thinkingText": "springViolet1",

    // ═════════════════════════════════════════════════════════════════════════
    // Backgrounds & Content (11 colors)
    // ═════════════════════════════════════════════════════════════════════════

    "selectedBg": "sumiInk3",
    "userMessageBg": "winterBlue",
    "userMessageText": "",
    "customMessageBg": "winterGreen",
    "customMessageText": "",
    "customMessageLabel": "crystalBlue",
    "toolPendingBg": "sumiInk4",
    "toolSuccessBg": "winterGreen",
    "toolErrorBg": "#2d1f2a",
    "toolTitle": "",
    "toolOutput": "fujiGray",

    // ═════════════════════════════════════════════════════════════════════════
    // Markdown (10 colors)
    // ═════════════════════════════════════════════════════════════════════════

    "mdHeading": "springBlue",
    "mdLink": "springBlue",
    "mdLinkUrl": "dragonBlue",
    "mdCode": "carpYellow",
    "mdCodeBlock": "sumiInk0",
    "mdCodeBlockBorder": "",
    "mdQuote": "waveAqua",
    "mdQuoteBorder": "waveAqua",
    "mdHr": "sumiInk4",
    "mdListBullet": "springGreen",

    // ═════════════════════════════════════════════════════════════════════════
    // Tool Diffs (3 colors)
    // ═════════════════════════════════════════════════════════════════════════

    "toolDiffAdded": "springGreen",
    "toolDiffRemoved": "peachRed",
    "toolDiffContext": "fujiGray",

    // ═════════════════════════════════════════════════════════════════════════
    // Syntax Highlighting (9 colors)
    // ═════════════════════════════════════════════════════════════════════════

    "syntaxComment": "fujiGray",
    "syntaxKeyword": "oniViolet",
    "syntaxFunction": "crystalBlue",
    "syntaxVariable": "crystalBlue",
    "syntaxString": "springGreen",
    "syntaxNumber": "sakuraPink",
    "syntaxType": "crystalBlue",
    "syntaxOperator": "surimiOrange",
    "syntaxPunctuation": "oldWhite",

    // ═════════════════════════════════════════════════════════════════════════
    // Thinking Level Borders (6 colors)
    // ═════════════════════════════════════════════════════════════════════════

    "thinkingOff": "fujiGray",
    "thinkingMinimal": "springViolet1",
    "thinkingLow": "dragonBlue",
    "thinkingMedium": "crystalBlue",
    "thinkingHigh": "oniViolet",
    "thinkingXhigh": "peachRed",

    // ═════════════════════════════════════════════════════════════════════════
    // Bash Mode (1 color)
    // ═════════════════════════════════════════════════════════════════════════

    "bashMode": "surimiOrange"
  }
}